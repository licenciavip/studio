rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Usuario bloqueado no puede escribir nada.
    function notBlocked() {
      return isSignedIn()
        && !(exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('blocked', false) == true);
    }

    // ─── users ───────────────────────────────────────────────────────────────
    // Allowlist estricta: usuario solo puede editar displayName y avatarSeed.
    // uid, email, role, blocked, createdAt son inmutables desde cliente.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && (!('role' in request.resource.data) || request.resource.data.role == 'user')
        && (!('blocked' in request.resource.data) || request.resource.data.blocked == false);
      allow update: if isAdmin()
        || (isOwner(userId) && notBlocked()
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.get('email', '') == resource.data.get('email', '')
            && request.resource.data.role == resource.data.role
            && request.resource.data.get('blocked', false) == resource.data.get('blocked', false)
            && request.resource.data.get('createdAt', null) == resource.data.get('createdAt', null)
            && request.resource.data.keys().hasOnly(
                ['uid','email','displayName','role','blocked','createdAt','updatedAt','avatarSeed']));
      allow delete: if isAdmin();
    }

    // ─── paymentOrders ───────────────────────────────────────────────────────
    // Cliente solo puede crear con campos controlados; monto/estado no pueden
    // ser arbitrarios: el admin es quien aprueba; la validación real de montos
    // ocurre en la revisión manual (hasta tener Cloud Functions).
    match /paymentOrders/{orderId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && notBlocked()
        && isOwner(request.resource.data.userId)
        && request.resource.data.status in ['pending', 'uploaded']
        && request.resource.data.type in ['wallet_recharge', 'membership_payment']
        && request.resource.data.keys().hasOnly([
            'id','userId','type','relatedGroupId','amountExpected','amountPaid',
            'currency','paymentCode','operationNumber','bankDestination',
            'destinationAccountNumber','payerName','status','reviewStatus',
            'expiresAt','createdAt','updatedAt']);
      allow update, delete: if isAdmin();
    }

    // ─── wallets ─────────────────────────────────────────────────────────────
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // ─── withdrawals ─────────────────────────────────────────────────────────
    match /withdrawals/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && notBlocked()
        && isOwner(request.resource.data.userId)
        && request.resource.data.status == 'pending'
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.keys().hasOnly([
            'id','userId','amount','currency','entity','destination','holderName',
            'docNumber','accountId','status','createdAt','updatedAt']);
      allow update, delete: if isAdmin();
    }

    // ─── withdrawalAccounts ──────────────────────────────────────────────────
    // status siempre 'pending' al crear; solo admin lo cambia.
    match /withdrawalAccounts/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && notBlocked()
        && isOwner(request.resource.data.userId)
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly([
            'id','userId','accountName','entity','destination','holderName',
            'docType','docNumber','isPrimary','status','createdAt','updatedAt']);
      allow update, delete: if isAdmin();
    }

    // ─── disputes ────────────────────────────────────────────────────────────
    // La orden referenciada DEBE pertenecer al usuario que abre la disputa.
    match /disputes/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && notBlocked()
        && isOwner(request.resource.data.userId)
        && request.resource.data.status == 'open'
        && request.resource.data.orderId is string
        && exists(/databases/$(database)/documents/paymentOrders/$(request.resource.data.orderId))
        && get(/databases/$(database)/documents/paymentOrders/$(request.resource.data.orderId)).data.userId == request.auth.uid
        && get(/databases/$(database)/documents/paymentOrders/$(request.resource.data.orderId)).data.status == 'approved'
        && request.resource.data.keys().hasOnly([
            'id','userId','orderId','evidence','status','createdAt','updatedAt']);
      allow update, delete: if isAdmin();
    }

    // ─── groups ──────────────────────────────────────────────────────────────
    // Solo grupos aprobados son visibles para todos los autenticados.
    // Pendientes y rechazados solo los lee su host o el admin.
    // Host no puede borrar grupos con miembros; eso lo hace el admin.
    match /groups/{id} {
      allow read: if isAdmin()
        || resource.data.get('approval','') == 'approved'
        || (isSignedIn() && resource.data.hostId == request.auth.uid);
      allow create: if isSignedIn() && notBlocked()
        && isOwner(request.resource.data.hostId)
        && request.resource.data.approval == 'pending'
        && request.resource.data.slotsFilled == 0
        && request.resource.data.memberIds.size() == 0;
      allow update: if isAdmin();
      allow delete: if isAdmin()
        || (isOwner(resource.data.hostId) && notBlocked()
            && resource.data.memberIds.size() == 0);

      // Credenciales privadas: solo host/miembros/admin.
      match /private/{doc} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/groups/$(id)).data.hostId == request.auth.uid
          || request.auth.uid in get(/databases/$(database)/documents/groups/$(id)).data.memberIds
          || isAdmin()
        );
        allow write: if isSignedIn() && (
          (get(/databases/$(database)/documents/groups/$(id)).data.hostId == request.auth.uid && notBlocked())
          || isAdmin()
        );
      }
    }

    // ─── services ────────────────────────────────────────────────────────────
    match /services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── config ──────────────────────────────────────────────────────────────
    // Datos de pago solo para usuarios autenticados en flujo activo.
    match /config/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── usernames ───────────────────────────────────────────────────────────
    // Slug -> uid. No se puede reasignar a otro uid.
    match /usernames/{slug} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ─── publicProfiles ──────────────────────────────────────────────────────
    // CRÍTICO #2 fix: allowlist estricta.
    // El usuario SOLO puede editar: displayName, avatarSeed, bio, slug, updatedAt.
    // Campos de confianza (verified*, rating*, score, tierKey) SOLO los escribe el admin/backend.
    // uid debe siempre coincidir con el doc id.
    // Se elimina la rama de "reviewer actualiza perfil del host" — solo admin puede.
    match /publicProfiles/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) && notBlocked()
        && request.resource.data.uid == uid
        && !('phone' in request.resource.data)
        && !('whatsapp' in request.resource.data)
        && !('verifiedEmail' in request.resource.data)
        && !('verifiedProfile' in request.resource.data)
        && !('score' in request.resource.data)
        && !('tierKey' in request.resource.data);
      allow update: if isAdmin()
        || (isOwner(uid) && notBlocked()
            && request.resource.data.uid == uid
            && !('phone' in request.resource.data)
            && !('whatsapp' in request.resource.data)
            && request.resource.data.get('ratingSum', 0) == resource.data.get('ratingSum', 0)
            && request.resource.data.get('ratingCount', 0) == resource.data.get('ratingCount', 0)
            && request.resource.data.get('verifiedEmail', false) == resource.data.get('verifiedEmail', false)
            && request.resource.data.get('verifiedProfile', false) == resource.data.get('verifiedProfile', false)
            && request.resource.data.get('score', 0) == resource.data.get('score', 0)
            && request.resource.data.get('tierKey', '') == resource.data.get('tierKey', '')
            && request.resource.data.keys().hasOnly([
                'uid','displayName','avatarSeed','bio','slug',
                'createdAt','updatedAt','ratingSum','ratingCount',
                'verifiedEmail','verifiedProfile','score','tierKey']));
    }

    // Datos privados del perfil: contacto no publico.
    match /privateProfiles/{uid} {
      allow read, create, update: if (isOwner(uid) && notBlocked()) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── reviews ─────────────────────────────────────────────────────────────
    // Allowlist de campos; límite de longitud en comment; raterName derivado del
    // perfil (no editable para suplantar a otros).
    match /reviews/{id} {
      allow read: if true;
      allow create, update: if isSignedIn() && notBlocked()
        && request.resource.data.raterId == request.auth.uid
        && id == request.resource.data.hostId + '__' + request.auth.uid
        && request.resource.data.stars is number
        && request.resource.data.stars >= 1 && request.resource.data.stars <= 5
        && request.resource.data.get('comment', '').size() <= 500
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.memberIds
        && get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.hostId == request.resource.data.hostId
        && request.resource.data.keys().hasOnly([
            'id','hostId','raterId','raterName','groupId','stars','comment','createdAt','updatedAt']);
      allow delete: if isAdmin();
    }

    // ─── serviceRecommendations ──────────────────────────────────────────────
    match /serviceRecommendations/{id} {
      allow create: if isSignedIn() && notBlocked()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.get('serviceName', '').size() <= 100
        && request.resource.data.keys().hasOnly(['userId','serviceName','comment','createdAt']);
      allow read: if isAdmin();
    }

    // ─── adminLogs ───────────────────────────────────────────────────────────
    // Solo lectura/creación admin; nunca se puede modificar ni borrar.
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
