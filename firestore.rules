rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Autorización REAL de admin: custom claim del token de Firebase Auth.
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // FIX #6: un usuario bloqueado no puede escribir nada (ni pegándole a
    // Firestore directo). Lee su propio doc para ver la marca `blocked`.
    function notBlocked() {
      return isSignedIn()
        && !(exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('blocked', false) == true);
    }

    // FIX #1: cada quien lee SOLO su propio documento (el admin, todos).
    // Antes cualquier logueado leía el email de todos.
    // El usuario no puede cambiar `role` ni `blocked` (eso es solo del admin).
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && (!('role' in request.resource.data) || request.resource.data.role == 'user')
        && (!('blocked' in request.resource.data) || request.resource.data.blocked == false);
      allow update: if isAdmin()
        || (isOwner(userId) && notBlocked()
            && request.resource.data.role == resource.data.role
            && request.resource.data.get('blocked', false) == resource.data.get('blocked', false));
      allow delete: if isAdmin();
    }

    // FIX #2 y #3: crear solo órdenes propias, con estado inicial válido; el
    // usuario YA NO puede modificarlas (los flujos crean la orden completa de
    // una vez). Solo el admin las actualiza.
    match /paymentOrders/{orderId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && notBlocked()
        && isOwner(request.resource.data.userId)
        && request.resource.data.status in ['pending', 'uploaded']
        && request.resource.data.type in ['wallet_recharge', 'membership_payment'];
      allow update, delete: if isAdmin();
    }

    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // Retiros: el usuario crea los suyos con monto positivo; el admin los gestiona.
    match /withdrawals/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && notBlocked()
        && isOwner(request.resource.data.userId)
        && request.resource.data.status == 'pending'
        && request.resource.data.amount is number
        && request.resource.data.amount > 0;
      allow update, delete: if isAdmin();
    }

    match /withdrawalAccounts/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && notBlocked() && isOwner(request.resource.data.userId);
      allow update, delete: if (isOwner(resource.data.userId) && notBlocked()) || isAdmin();
    }

    match /disputes/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && notBlocked()
        && isOwner(request.resource.data.userId)
        && request.resource.data.status == 'open';
      allow update, delete: if isAdmin();
    }

    // Grupos: listado legible por usuarios autenticados (para explorar).
    // Crear en revisión; actualizar solo el admin (aprobar, sumar miembros);
    // borrar el dueño o el admin. Las credenciales van en subcolección privada.
    match /groups/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && notBlocked()
        && isOwner(request.resource.data.hostId)
        && request.resource.data.approval == 'pending'
        && request.resource.data.slotsFilled == 0
        && request.resource.data.memberIds.size() == 0;
      allow update: if isAdmin();
      allow delete: if isOwner(resource.data.hostId) || isAdmin();

      match /private/{doc} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/groups/$(id)).data.hostId == request.auth.uid
          || request.auth.uid in get(/databases/$(database)/documents/groups/$(id)).data.memberIds
          || isAdmin()
        );
        allow write: if isSignedIn() && (
          (get(/databases/$(database)/documents/groups/$(id)).data.hostId == request.auth.uid && notBlocked())
          || isAdmin()
        );
      }
    }

    // Catálogo de servicios y configuración: lectura pública, escritura admin.
    match /services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /serviceRecommendations/{id} {
      allow create: if isSignedIn() && notBlocked();
      allow read: if isAdmin();
    }

    // Registro de acciones administrativas: inmutable desde el cliente.
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
