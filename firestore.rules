rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Autorización REAL de admin: custom claim del token de Firebase Auth.
    // NO depende de ningún campo editable de Firestore.
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // El usuario gestiona su propio documento, pero NO puede tocar campos
    // sensibles como `role` para auto-promoverse (la autorización real es la
    // custom claim, pero igual blindamos el documento).
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
        && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if (isOwner(userId)
                        && request.resource.data.role == resource.data.role)
                    || isAdmin();
      allow delete: if isAdmin();
    }

    match /paymentOrders/{orderId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn();
      allow update: if (isOwner(resource.data.userId)
                        && resource.data.status in ['pending', 'uploaded'])
                    || isAdmin();
      allow delete: if isAdmin();
    }

    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Solo el backend admin ajusta saldos.
      allow write: if isAdmin();
    }

    // Solicitudes de retiro: el usuario crea las suyas; el admin las gestiona.
    // El usuario no puede cambiar el estado ni el monto una vez creada.
    match /withdrawals/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn()
        && isOwner(request.resource.data.userId)
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // Cuentas de retiro registradas por el usuario.
    match /withdrawalAccounts/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Disputas: el usuario abre las suyas; solo el admin las resuelve.
    match /disputes/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn()
        && isOwner(request.resource.data.userId)
        && request.resource.data.status == 'open';
      allow update, delete: if isAdmin();
    }

    // Grupos (publicaciones de suscripción). Por ahora solo el anfitrión y el
    // admin pueden leerlos (contienen credenciales). El navegar grupos de otros
    // usuarios se habilitará con un modelo de miembros que separe las credenciales.
    // Al crear, el grupo entra en revisión (approval == 'pending'). El dueño NO
    // puede cambiar el estado de aprobación; solo el admin.
    // El documento del grupo es el LISTADO (sin credenciales): cualquier usuario
    // autenticado puede leerlo para explorar. Las credenciales viven en la
    // subcolección privada de abajo.
    match /groups/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && isOwner(request.resource.data.hostId)
        && request.resource.data.approval == 'pending';
      // El dueño puede editar sin tocar aprobación ni miembros; el admin todo
      // (aprobar, agregar miembros al validar el pago).
      allow update: if isAdmin()
        || (isOwner(resource.data.hostId)
            && request.resource.data.approval == resource.data.approval
            && request.resource.data.memberIds == resource.data.memberIds);
      allow delete: if isOwner(resource.data.hostId) || isAdmin();

      // Credenciales: solo el dueño, los miembros del grupo y el admin.
      match /private/{doc} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/groups/$(id)).data.hostId == request.auth.uid
          || request.auth.uid in get(/databases/$(database)/documents/groups/$(id)).data.memberIds
          || isAdmin()
        );
        allow write: if isSignedIn() && (
          get(/databases/$(database)/documents/groups/$(id)).data.hostId == request.auth.uid
          || isAdmin()
        );
      }
    }

    // Catálogo de servicios: lectura pública, escritura solo admin.
    match /services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /serviceRecommendations/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    // Registro de acciones administrativas: inmutable desde el cliente.
    // Solo un admin puede crear; nadie puede actualizar ni borrar.
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
